{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "only-talk",
  "version": "1.0.0",
  "identifier": "com.only.talk.app",
  "build": {
    "frontendDist": "../apps/pc/dist",
    "devUrl": "http://localhost:8080",
    "beforeDevCommand": "pnpm --filter @workspace/app-pc dev",
    "beforeBuildCommand": "pnpm --filter @workspace/app-pc build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "歪比巴卜",
        "width": 380,
        "height": 480,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": true,
        "center": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["window-default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resource/default.jpg"
    ]
  }
}
